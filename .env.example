# =============================================================================
# Variables de entorno — Hotel San Francisco API
# Copia este archivo como referencia para configurar Railway (o tu entorno).
# Los valores aquí son EJEMPLOS; reemplázalos por valores reales y secretos.
# =============================================================================

# --- Base de datos (PostgreSQL) -------------------------------------------
# En Railway, referencia el servicio Postgres con plantillas:
#   DATABASE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
#   DATABASE_USERNAME=${{Postgres.PGUSER}}
#   DATABASE_PASSWORD=${{Postgres.PGPASSWORD}}
# Nota: la URL DEBE empezar con jdbc:postgresql:// (no el postgresql:// crudo).
DATABASE_URL=jdbc:postgresql://localhost:5432/hotel_sf
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changeme

# --- Servidor --------------------------------------------------------------
# Railway inyecta PORT automáticamente; normalmente NO necesitas definirlo.
# PORT=8080
APP_TIMEZONE=America/Lima

# --- Seguridad / JWT -------------------------------------------------------
# Clave de al menos 32 caracteres. Genera una aleatoria y mantenla secreta.
JWT_SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria_de_32+_chars
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# --- Cookies ---------------------------------------------------------------
# En producción (HTTPS): secure=true. Si el frontend está en OTRO dominio,
# same-site debe ser None (requiere secure=true) para enviar cookies cross-site.
APP_COOKIE_SECURE=true
APP_COOKIE_SAMESITE=None

# --- CORS / Frontend -------------------------------------------------------
# Dominio(s) del frontend separados por coma (sin barra final).
APP_CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app
APP_FRONTEND_URL=https://tu-frontend.vercel.app

# --- Notificaciones (cifrado de credenciales SMTP en BD) -------------------
# El SMTP en sí se configura desde el panel (tabla smtp_config); esta clave
# cifra/descifra esas credenciales. Debe ser estable entre despliegues.
SMTP_CIPHER_KEY=cambia_esta_clave_de_cifrado_smtp

# --- Integración RENIEC (apisperu.com) -------------------------------------
RENIEC_TOKEN=tu_token_de_apisperu
RENIEC_ENABLED=true
# RENIEC_API_URL=https://dniruc.apisperu.com/api/v1/dni

# --- Reserva online --------------------------------------------------------
RESERVA_ONLINE_USUARIO_ID=1
RESERVA_ONLINE_CANAL_NOMBRE=ONLINE

# --- Cache (opcional; tienen defaults) -------------------------------------
# CACHE_MAX_SIZE=1000
# CACHE_EXPIRE_AFTER_WRITE=15m

# --- Logging (opcional; en producción conviene bajar el verbosity) ---------
LOG_LEVEL_SQL=WARN
LOG_LEVEL_BIND=WARN
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_FLYWAY=INFO

# --- Actuator (opcional) ---------------------------------------------------
# ACTUATOR_EXPOSE=health
